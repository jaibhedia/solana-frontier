# uWu Protocol — environment variables
# Copy to .env and fill in values. .env is gitignored — never commit real credentials.

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.xyz
NEXT_PUBLIC_APP_VERSION=v0.9.2
NEXT_PUBLIC_BETA_LABEL=India · UPI settlement · Solana devnet

# ── Solana ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=G8LyjnQ6xYW2txzk2nbiUpcdGC82AvmcXuMSEhSjutXU

# ── Oracle keypair ────────────────────────────────────────────────────────────
# 64-byte Solana keypair as base58 (solana-keygen new --outfile oracle.json)
ORACLE_SECRET_KEY=your-base58-64-byte-keypair
# 32-byte ed25519 pubkey as hex (last 32 bytes of decoded keypair)
NEXT_PUBLIC_ORACLE_PUBKEY_HEX=your-64-char-hex-pubkey

# Verification mode: "mock" (auto-approve) | "setu" (real Setu AA verification)
VERIFICATION_MODE=setu
NEXT_PUBLIC_VERIFICATION_MODE=setu

# ── Setu Account Aggregator ────────────────────────────────────────────────────
# Sandbox:    SETU_TOKEN_URL=https://uat.setu.co/api/v2/auth/token
#             SETU_FIU_BASE_URL=https://fiu-sandbox.setu.co
# Production: SETU_TOKEN_URL=https://api.setu.co/api/v2/auth/token
#             SETU_FIU_BASE_URL=https://fiu.setu.co
SETU_TOKEN_URL=https://uat.setu.co/api/v2/auth/token
SETU_FIU_BASE_URL=https://fiu-sandbox.setu.co
SETU_CLIENT_ID=your-setu-client-id
SETU_CLIENT_SECRET=your-setu-client-secret
SETU_PRODUCT_INSTANCE_ID=your-product-instance-id

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon-key
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key
SUPABASE_WAITLIST_TABLE=waitlist_submissions
